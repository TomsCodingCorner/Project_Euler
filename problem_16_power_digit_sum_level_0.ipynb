   "source": [
    "def sum_of_power(power)->int:\n",
    "    result = 2 ** power\n",
    "    count = 0\n",
    "    for i in str(result):\n",
    "        count += int(i)\n",
    "    return count\n",
    "\n",
    "print(sum_of_power(1000))"
   ]
