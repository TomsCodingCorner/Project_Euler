   "source": [
    "def fibonacci(limit: int) -> int:\n",
    "    f1 = 1\n",
    "    f2 = 1\n",
    "    index = 1\n",
    "    \n",
    "    while(len(str(f1)) < limit):\n",
    "        f1, f2 = f2, f1 + f2\n",
    "        index += 1\n",
    "    return index\n",
    "\n",
    "print(fibonacci(1000))\n",
    "\n"
   ]
